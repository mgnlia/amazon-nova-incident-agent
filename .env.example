# AWS Credentials (for real Bedrock access)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# Nova model ID (Amazon Nova Pro via Bedrock)
NOVA_MODEL_ID=amazon.nova-pro-v1:0

# Set to "mock" to use mock responses (no AWS needed), "bedrock" for real
AGENT_MODE=mock
